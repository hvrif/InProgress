{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-handoff.sh",
            "shell": "bash",
            "timeout": 10,
            "statusMessage": "Checking for handoff notes..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-handoff.sh",
            "shell": "bash",
            "timeout": 10,
            "statusMessage": "Checking for uncommitted work to hand off..."
          }
        ]
      }
    ]
  }
}
